ate-900 text-white relative overflow-hidden"><div class="container mx-auto px-4 relative z-10"><div class="text-center max-w-2xl mx-auto mb-16"> <span class="text-cyan-300 font-bold tracking-widest text-xs uppercase mb-2 block">Engineering Tools</span><h2 class="text-4xl font-black mb-4 text-white">Industrial Diagnostics</h2><p class="text-slate-300">Advanced calculators and tools to help you make the right engineering decisions.</p></div><div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12"><div class="bg-slate-800 border border-slate-600 p-8 rounded-2xl shadow-2xl"><div class="flex justify-between items-center mb-6"><h3 class="text-2xl font-bold flex items-center gap-3 text-white"><i class="fa-solid fa-calculator text-blue-400"></i> Tonnage Calculator</h3></div><form id="ac-calc-form" class="space-y-4" onsubmit="return false;"><div class="grid grid-cols-2 gap-4"> <input type="number" id="length" placeholder="Length (ft)" aria-label="Room Length" step="any" min="0" class="w-full p-3 bg-slate-950 border border-slate-600 rounded-lg text-white" required> <input type="number" id="width" placeholder="Width (ft)" aria-label="Room Width" step="any" min="0" class="w-full p-3 bg-slate-950 border border-slate-600 rounded-lg text-white" required></div> <button type="submit" class="bg-blue-700 text-white px-6 py-3 rounded-lg font-bold w-full hover:bg-blue-600 transition">Calculate</button></form><div id="result-box" class="hidden mt-6 text-center bg-slate-950 p-6 rounded-xl border border-blue-500/50"> <span class="text-sm text-blue-300 font-bold uppercase">You Need</span><div class="text-5xl font-black text-white my-2"><span id="tonnage-result">1.5</span> T</div><p class="text-sm text-slate-300" id="btu-detail"></p></div></div><div class="bg-slate-800 border border-slate-600 p-8 rounded-2xl shadow-2xl"><div class="flex justify-between items-center mb-6"><h3 class="text-2xl font-bold flex items-center gap-3 text-white"><i class="fa-solid fa-bolt text-green-400"></i> Bill Estimator</h3></div><form id="power-calc-form" class="space-y-4" onsubmit="return false;"> <select id="ac-type" aria-label="Select AC Type" class="w-full p-3 bg-slate-950 border border-slate-600 rounded-lg text-white"><option value="1.1">1.5 Ton Inverter (5 Star)</option><option value="1.6">1.5 Ton Non-Inverter</option> </select><div class="grid grid-cols-2 gap-4"> <input type="number" id="hours" placeholder="Hours/Day" aria-label="Hours of use per day" step="any" min="0" class="w-full p-3 bg-slate-950 border border-slate-600 rounded-lg text-white" required> <input type="number" id="rate" value="7.5" placeholder="Rate/Unit" aria-label="Electricity Rate per Unit" step="any" min="0" class="w-full p-3 bg-slate-950 border border-slate-600 rounded-lg text-white" required></div> <button type="submit" class="bg-green-700 text-white px-6 py-3 rounded-lg font-bold w-full hover:bg-green-600 transition">Check Cost</button></form><div id="power-result-box" class="hidden mt-6 text-center bg-slate-950 p-6 rounded-xl border border-green-500/50"> <span class="text-sm text-green-400 font-bold uppercase">Monthly Bill</span><div class="text-5xl font-black text-white my-2">₹<span id="monthly-cost">0</span></div><p class="text-sm text-slate-300" id="unit-detail"></p></div></div></div></div></section><section class="section-padding bg-slate-50 border-b border-slate-300"><div class="container mx-auto px-4"><div class="flex justify-between items-end mb-12"><div><span class="text-blue-800 font-bold tracking-wider uppercase text-sm">Atlas Store</span><h2 class="text-3xl font-bold text-slate-900 mt-2">Genuine Spare Parts</h2></div> <a href="/shop" class="hidden md:inline-flex items-center font-bold text-blue-800 hover:text-blue-900" aria-label="View all spare parts">View All Parts <i class="fa-solid fa-arrow-right ml-2"></i></a></div><div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6"><div class="bg-white rounded-xl shadow-sm hover:shadow-xl transition group overflow-hidden border 