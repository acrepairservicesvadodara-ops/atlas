ppercase;box-shadow:0 10px 15px -3px rgba(34,197,94,.4);transition:.3s}.atlas-diag-cta:hover{background:#16a34a;transform:translateY(-2px);color:#fff}
.atlas-footer{background-color:#0f172a;color:#94a3b8;font-family:system-ui,-apple-system,sans-serif;padding-top:60px;padding-bottom:40px;border-top:4px solid #0ea5e9;position:relative}.atlas-container{max-width:1200px;margin:0 auto;padding:0 20px}.footer-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:40px;margin-bottom:40px}.footer-heading{color:#fff;font-size:12px;font-weight:900;text-transform:uppercase;letter-spacing:2px;margin-bottom:20px;border-left:3px solid #0ea5e9;padding-left:15px}.footer-text{font-size:14px;line-height:1.6;color:#64748b;margin-top:0}.footer-link{display:block;color:#94a3b8;text-decoration:none;margin-bottom:12px;font-size:14px;transition:.2s;font-weight:500}.footer-link:hover{color:#0ea5e9;transform:translateX(5px)}.social-icons{display:flex;gap:15px;margin-top:20px}.social-link{color:#64748b;font-size:18px;transition:.3s}.social-link:hover{color:#fff}.contact-item{display:flex;align-items:start;gap:15px;margin-bottom:15px;font-size:14px}.contact-icon{color:#0ea5e9;margin-top:3px}.footer-matrix{border-top:1px solid rgba(255,255,255,.05);padding-top:30px;margin-top:30px}.matrix-title{font-size:10px;font-weight:900;color:#475569;text-transform:uppercase;letter-spacing:3px;margin-bottom:15px}.matrix-tags{font-size:11px;font-weight:700;color:#475569;line-height:1.8;text-transform:uppercase}.matrix-tags span{margin-right:8px}.copyright-bar{display:flex;flex-wrap:wrap;justify-content:space-between;border-top:1px solid rgba(255,255,255,.05);padding-top:30px;margin-top:30px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px}.mobile-sticky-bar{display:none;position:fixed;bottom:0;left:0;width:100%;height:60px;background:#fff;box-shadow:0 -5px 20px rgba(0,0,0,.1);z-index:9999}.sticky-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-decoration:none;border-right:1px solid #f1f5f9}.sticky-label{font-size:9px;font-weight:900;text-transform:uppercase;margin-top:4px}@media (max-width:768px){.mobile-sticky-bar{display:flex}.atlas-footer{padding-bottom:80px}.copyright-bar{flex-direction:column;gap:10px;text-align:center}}
.atlas-interceptor-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(15,23,42,.85);backdrop-filter:blur(8px);z-index:9999999;display:flex;align-items:center;justify-content:center;opacity:0;visibility:hidden;transition:all .4s ease}.atlas-interceptor-overlay.active{opacity:1;visibility:visible}.atlas-interceptor-box{background:#fff;width:90%;max-width:500px;border-radius:16px;padding:40px 30px;text-align:center;position:relative;transform:translateY(50px);transition:transform .4s cubic-bezier(.175,.885,.32,1.275);box-shadow:0 25px 50px -12px rgba(0,0,0,.5);border-top:8px solid #ef4444}.atlas-interceptor-overlay.active .atlas-interceptor-box{transform:translateY(0)}.atlas-interceptor-close{position:absolute;top:15px;right:20px;font-size:24px;color:#94a3b8;cursor:pointer;transition:.3s}.atlas-interceptor-close:hover{color:#0f172a}.atlas-interceptor-icon{width:80px;height:80px;background:#fee2e2;color:#ef4444;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:36px;margin:0 auto 20px;animation:pulse-red 2s infinite}@keyframes pulse-red{0%{box-shadow:0 0 0 0 rgba(239,68,68,.4)}70%{box-shadow:0 0 0 15px rgba(239,68,68,0)}100%{box-shadow:0 0 0 0 rgba(239,68,68,0)}}.atlas-btn-urgent{display:inline-flex;align-items:center;justify-content:center;background:#22c55e;color:#fff;font-weight:900;font-size:18px;padding:16px 30px;border-radius:12px;text-decoration:none;width:100%;margin-top:20px;text-transform:uppercase;letter-spacing:.5px;box-shadow:0 10px 15px -3px rgba(34,197,94,.4);transition:.3s}.atlas-btn-urgent:hover{background:#16a34a;transform:translateY(-2px);color:#fff}
